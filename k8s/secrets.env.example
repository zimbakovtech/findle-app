# Copy this file to k8s/secrets.env and fill in real values.
# secrets.env is gitignored — never commit it.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=findle_db

# Must match above: postgresql+asyncpg://<USER>:<PASSWORD>@postgres:5432/<DB>
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/findle_db

# Generate with: openssl rand -hex 32
SECRET_KEY=your-strong-secret-key-here

FIRST_SUPERUSER_PASSWORD=changeme
